{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"extends": ["../biome.json"],
	"linter": {
		"rules": {
			"correctness": {
				"noUndeclaredDependencies": "off",
				"noNodejsModules": "off"
			},
			"suspicious": {
				"noConsole": "off",
				"noConsoleLog": "off"
			},
			"style": {
				"noDefaultExport": "off",
				"useNamingConvention": "off"
			}
		}
	}
}
