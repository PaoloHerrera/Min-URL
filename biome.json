{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": [
			"node_modules",
			"dist",
			"build",
			"src/modules/core/ui",
			"**/*.astro",
			"__test__"
		]
	},
	"formatter": {
		"enabled": false,
		"indentStyle": "tab"
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"ignore": ["google.strategy.ts", "models", "schema"],
		"enabled": true,
		"rules": {
			"all": true,
			"suspicious": {
				"noReactSpecificProps": "off"
			}
		}
	},
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		},
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"json": {
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": true
		}
	},
	"overrides": [
		{
			"include": ["**/frontend-landing/**", "frontend-landing/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredDependencies": "off"
					},
					"suspicious": {
						"noReactSpecificProps": "off"
					}
				}
			}
		},
		{
			"include": ["**/frontend-dashboard/**", "frontend-dashboard/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredDependencies": "off"
					},
					"suspicious": {
						"noReactSpecificProps": "off"
					}
				}
			}
		},
		{
			"include": ["**/backend-services/**", "backend-services/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredDependencies": "off",
						"noNodejsModules": "off"
					},
					"suspicious": {
						"noConsole": "off",
						"noConsoleLog": "off"
					},
					"style": {
						"noDefaultExport": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"include": ["**/backend-users/**", "backend-users/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredDependencies": "off",
						"noNodejsModules": "off"
					},
					"suspicious": {
						"noConsole": "off",
						"noConsoleLog": "off"
					},
					"style": {
						"noDefaultExport": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"include": ["**/backend-redirector/**", "backend-redirector/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredDependencies": "off",
						"noNodejsModules": "off"
					},
					"suspicious": {
						"noConsole": "off",
						"noConsoleLog": "off",
						"noReactSpecificProps": "off"
					}
				}
			}
		},
		{
			"include": [
				"**/backend-redirector/vite.config.ts",
				"backend-redirector/vite.config.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"include": [
				"**/backend-redirector/app/routes/**",
				"backend-redirector/app/routes/**",
				"**/backend-redirector/app/root.tsx",
				"backend-redirector/app/root.tsx"
			],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off",
						"useFilenamingConvention": "off"
					}
				}
			}
		},
		{
			"include": [
				"**/backend-users/src/**/*.spec.ts",
				"backend-users/src/**/*.spec.ts",
				"src/**/*.spec.ts",
				"**/backend-users/test/**/*.e2e-spec.ts",
				"backend-users/test/**/*.e2e-spec.ts",
				"test/**/*.e2e-spec.ts"
			],
			"javascript": {
				"globals": [
					"describe",
					"beforeEach",
					"it",
					"expect",
					"jest",
					"beforeAll",
					"afterAll",
					"afterEach"
				]
			}
		}
	]
}
