		"typecheck": "astro check --types",
		"typefix": "astro check --fix",
		"test": "vitest",
		"test:watch": "vitest watch",
		"coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
