	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"lint": "biome lint .",
		"lintfix": "biome lint --fix",
		"format": "prettier --write \"src/**/*.{astro,js,tsx,jsx,ts,css,json,md}\" --plugin=prettier-plugin-astro",
