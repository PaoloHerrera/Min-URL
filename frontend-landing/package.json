		"@types/node": "22.13.1",
		"@types/validator": "^13.15.10",
		"autoprefixer": "10.4.20",
		"daisyui": "^5.5.23",
		"happy-dom": "20.10.6",
		"msw": "2.14.6",
		"prettier": "^3.8.4",
