---
interface Props {
	class?: string
	id?: string
}
const { class: className = 'size-3', id } = Astro.props
---

<svg
	id={id}
	class={className}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="2.5"
	aria-hidden="true"
>
	<path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"></path>
</svg>
