---
interface Props {
	id?: string
	class?: string
}
const { id, class: className = 'size-5' } = Astro.props
---

<svg
	id={id}
	class={className}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="2"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	xmlns="http://www.w3.org/2000/svg"
>
	<line x1="4" x2="20" y1="12" y2="12"></line>
	<line x1="4" x2="20" y1="6" y2="6"></line>
	<line x1="4" x2="20" y1="18" y2="18"></line>
</svg>
