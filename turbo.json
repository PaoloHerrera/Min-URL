{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "build/**", ".astro/**"]
		},
		"lint": {
			"outputs": []
		},
		"test": {
			"outputs": []
		},
		"typecheck": {
			"outputs": []
		},
		"format:check": {
			"outputs": []
		},
		"dev": {
			"cache": false
		},
		"start": {}
	}
}
